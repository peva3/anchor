# Environment variables for Anchor development.
# Copy to .env (which is gitignored) and fill in values.
# Currently the template has no runtime secrets, but downstream projects will.

# CI / local audit
APP_ENV=development

# Future: when a project imports AGENTS.md, it may need:
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0
# OPENAI_API_KEY=sk-...  # NEVER commit
